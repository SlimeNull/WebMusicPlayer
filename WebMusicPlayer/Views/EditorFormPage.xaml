<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebMusicPlayer.Views.EditorFormPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#73000000">

    <Grid Padding="20">
        <Border MaximumWidthRequest="520"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1B22}"
                Padding="20,18">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#66000000"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.24" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="TitleLabel"
                               FontFamily="OpenSansSemibold"
                               FontSize="22" />
                        <Label x:Name="SubtitleLabel"
                               FontSize="13"
                               Opacity="0.74" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="6">
                    <Label x:Name="PrimaryLabel"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}"
                            BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}"
                            Padding="12,4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry x:Name="PrimaryEntry"
                               ClearButtonVisibility="WhileEditing"
                               ReturnType="Next"
                               Completed="OnPrimaryCompleted" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="6">
                    <Label x:Name="SecondaryLabel"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}"
                            BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}"
                            Padding="12,4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry x:Name="SecondaryEntry"
                               ClearButtonVisibility="WhileEditing"
                               Keyboard="Url"
                               ReturnType="Done"
                               Completed="OnSaveClicked" />
                    </Border>
                </VerticalStackLayout>

                <Label Grid.Row="3"
                       x:Name="ErrorLabel"
                       TextColor="#DC2626"
                       FontSize="12"
                       IsVisible="False" />

                <Border Grid.Row="4"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F6F4FF, Dark=#242036}"
                        Padding="12,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label x:Name="HintLabel"
                           Text="地址必须是有效的 http/https 地址。支持音频流与 m3u8。"
                           FontSize="12"
                           Opacity="0.72" />
                </Border>

                <Grid Grid.Row="5"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Text="取消"
                            BackgroundColor="{AppThemeBinding Light=#ECE8FB, Dark=#2D2741}"
                            TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                            Clicked="OnCancelClicked" />
                    <Button Grid.Column="1"
                            x:Name="SaveButton"
                            Clicked="OnSaveClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
