<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WebMusicPlayer.Views.FavouritesPage"
             x:Name="FavouritesRoot">

    <Grid RowDefinitions="Auto,*">
        <Border StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=#F1EEFF, Dark=#1E1830}"
                Padding="14,12"
                Margin="0,0,0,12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Label Text="{Binding FavouritesSummaryText}"
                   FontSize="13"
                   Opacity="0.8" />
        </Border>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding FavouriteStreams}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="24"
                                     Spacing="10"
                                     VerticalOptions="Center">
                    <Label Text="★ 还没有喜欢的媒体流"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           HorizontalTextAlignment="Center" />
                    <Label Text="在 Streams 页面左滑一个项目，就会出现在这里。"
                           HorizontalTextAlignment="Center"
                           Opacity="0.72" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView Margin="0,0,0,12">
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Execute"
                                        SwipeBehaviorOnInvoked="Close">
                                <SwipeItem Text="归档"
                                           BackgroundColor="#64748B"
                                           Command="{Binding Source={x:Reference FavouritesRoot}, Path=BindingContext.ArchiveFavouriteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute"
                                        SwipeBehaviorOnInvoked="Close">
                                <SwipeItem Text="归档"
                                           BackgroundColor="#64748B"
                                           Command="{Binding Source={x:Reference FavouritesRoot}, Path=BindingContext.ArchiveFavouriteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1B22}"
                                Padding="16,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Name}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="16" />
                                <Label Grid.Column="1"
                                       Text="★"
                                       FontSize="20"
                                       TextColor="#F59E0B"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Row="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding Url}"
                                       FontSize="12"
                                       LineBreakMode="TailTruncation"
                                       Opacity="0.72" />
                                <Label Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="左滑或右滑可立即归档"
                                       FontSize="12"
                                       Opacity="0.6" />

                                <Button Grid.RowSpan="3"
                                        Grid.ColumnSpan="2"
                                        Text=""
                                        BackgroundColor="Transparent"
                                        BorderWidth="0"
                                        Command="{Binding Source={x:Reference FavouritesRoot}, Path=BindingContext.PlayStreamCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>
