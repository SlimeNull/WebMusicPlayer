<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:WebMusicPlayer.Models"
             xmlns:views="clr-namespace:WebMusicPlayer.Views"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="WebMusicPlayer.Views.MainPage"
             x:Name="RootPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F7F7FB, Dark=#101014}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,1">
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#191920}"
                Padding="16,18,16,10">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">
                <VerticalStackLayout Spacing="2">
                      <HorizontalStackLayout Spacing="8">
                       <Label Text="{Binding CurrentPageIconGlyph}"
                           FontFamily="{x:Static models:AppIcons.FontFamily}"
                           FontSize="24"
                           VerticalTextAlignment="Center" />
                       <Label Text="{Binding CurrentPageTitle}"
                           FontFamily="OpenSansSemibold"
                           FontSize="26" />
                      </HorizontalStackLayout>
                    <Label Text="WebMusicPlayer"
                           FontSize="12"
                           Opacity="0.68" />
                </VerticalStackLayout>

                <ImageButton Grid.Column="1"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="10"
                             CornerRadius="22"
                             BackgroundColor="{AppThemeBinding Light=#F2EFFF, Dark=#2B2440}"
                             IsVisible="{Binding ShowStreamsToolbar}"
                             Clicked="OnFilterClicked">
                    <ImageButton.Source>
                        <FontImageSource Glyph="{x:Static models:AppIcons.Filter}"
                                         FontFamily="{x:Static models:AppIcons.FontFamily}"
                                         Size="18"
                                         Color="{AppThemeBinding Light=#242424, Dark=White}" />
                    </ImageButton.Source>
                </ImageButton>

                <ImageButton Grid.Column="2"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="10"
                             CornerRadius="22"
                             BackgroundColor="{AppThemeBinding Light=#F2EFFF, Dark=#2B2440}"
                             IsVisible="{Binding ShowStreamsToolbar}"
                             Clicked="OnStreamsMenuClicked">
                    <ImageButton.Source>
                        <FontImageSource Glyph="{x:Static models:AppIcons.More}"
                                         FontFamily="{x:Static models:AppIcons.FontFamily}"
                                         Size="20"
                                         Color="{AppThemeBinding Light=#242424, Dark=White}" />
                    </ImageButton.Source>
                </ImageButton>

                <ImageButton Grid.Column="1"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="10"
                             CornerRadius="22"
                             BackgroundColor="{AppThemeBinding Light=#F2EFFF, Dark=#2B2440}"
                             IsVisible="{Binding ShowSubscriptionsToolbar}"
                             Clicked="OnUpdateSubscriptionsClicked">
                    <ImageButton.Source>
                        <FontImageSource Glyph="{x:Static models:AppIcons.Refresh}"
                                         FontFamily="{x:Static models:AppIcons.FontFamily}"
                                         Size="18"
                                         Color="{AppThemeBinding Light=#242424, Dark=White}" />
                    </ImageButton.Source>
                </ImageButton>

                <ImageButton Grid.Column="2"
                             WidthRequest="44"
                             HeightRequest="44"
                             Padding="10"
                             CornerRadius="22"
                             BackgroundColor="{AppThemeBinding Light=#F2EFFF, Dark=#2B2440}"
                             IsVisible="{Binding ShowSubscriptionsToolbar}"
                             Clicked="OnSubscriptionsMenuClicked">
                    <ImageButton.Source>
                        <FontImageSource Glyph="{x:Static models:AppIcons.More}"
                                         FontFamily="{x:Static models:AppIcons.FontFamily}"
                                         Size="20"
                                         Color="{AppThemeBinding Light=#242424, Dark=White}" />
                    </ImageButton.Source>
                </ImageButton>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Padding="16,8,16,12"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="10">
            <Button x:Name="buttonFavourites" 
                    Grid.Column="0"
                    Text="Favourites"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="Favourites"
                    BackgroundColor="{AppThemeBinding Light=#EAE7FB, Dark=#262033}"
                    TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                    ContentLayout="Left,8">
                <Button.ImageSource>
                    <FontImageSource x:Name="icon1" Glyph="{x:Static models:AppIcons.FavouriteFilled}"
                                     FontFamily="{x:Static models:AppIcons.FontFamily}"
                                     Size="16"
                                     Color="{Binding Source={x:Reference buttonFavourites},Path=TextColor}" />
                </Button.ImageSource>
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding SelectedTab}"
                                 Value="{x:Static models:AppTab.Favourites}">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#512BD4, Dark=#AC99EA}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Button x:Name="buttonStreams" 
                    Grid.Column="1"
                    Text="Streams"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="Streams"
                    BackgroundColor="{AppThemeBinding Light=#EAE7FB, Dark=#262033}"
                    TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                    ContentLayout="Left,8">
                <Button.ImageSource>
                    <FontImageSource x:Name="icon2" Glyph="{x:Static models:AppIcons.Stream}"
                                     FontFamily="{x:Static models:AppIcons.FontFamily}"
                                     Size="16"
                                     Color="{Binding Source={x:Reference buttonStreams},Path=TextColor}" />
                </Button.ImageSource>
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding SelectedTab}"
                                 Value="{x:Static models:AppTab.Streams}">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#512BD4, Dark=#AC99EA}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Button x:Name="buttonSubscriptions" Grid.Column="2"
                    Text="Subscriptions"
                    Command="{Binding SelectTabCommand}"
                    CommandParameter="Subscriptions"
                    BackgroundColor="{AppThemeBinding Light=#EAE7FB, Dark=#262033}"
                    TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                    ContentLayout="Left,8">
                <Button.ImageSource>
                    <FontImageSource x:Name="icon3" Glyph="{x:Static models:AppIcons.Subscription}"
                                     FontFamily="{x:Static models:AppIcons.FontFamily}"
                                     Size="16"
                                     Color="{Binding Source={x:Reference buttonSubscriptions},Path=TextColor}" />
                </Button.ImageSource>
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding SelectedTab}"
                                 Value="{x:Static models:AppTab.Subscriptions}">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#512BD4, Dark=#AC99EA}" />
                        <Setter Property="TextColor" Value="White" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <Grid Grid.Row="2"
              Padding="16,0,16,0">
            <views:FavouritesPage IsVisible="{Binding IsFavouritesVisible}" />
            <views:StreamsPage IsVisible="{Binding IsStreamsVisible}" />
            <views:SubscriptionsPage IsVisible="{Binding IsSubscriptionsVisible}" />
        </Grid>

        <Border Grid.Row="3"
                Margin="16,12,16,16"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1B22}"
                Padding="14,12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#88000000"
                        Offset="0,3"
                        Radius="12"
                        Opacity="0.18" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding CurrentStreamName}"
                           FontFamily="OpenSansSemibold"
                           FontSize="16" />
                    <Label Text="{Binding CurrentStreamSubtitle}"
                           FontSize="12"
                           Opacity="0.72" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="{Binding PlaybackButtonText}"
                        Command="{Binding TogglePlaybackCommand}"
                        ContentLayout="Left,8"
                        VerticalOptions="Center">
                    <Button.ImageSource>
                        <FontImageSource Glyph="{Binding PlaybackIconGlyph}"
                                         FontFamily="{x:Static models:AppIcons.FontFamily}"
                                         Size="18"
                                         Color="White" />
                    </Button.ImageSource>
                </Button>
            </Grid>
        </Border>

        <toolkit:MediaElement Grid.Row="4"
                              x:Name="Player"
                              HeightRequest="1"
                              WidthRequest="1"
                              Opacity="0.01"
                              ShouldAutoPlay="False"
                              ShouldShowPlaybackControls="False"
                              MediaEnded="OnPlayerMediaEnded"
                              MediaFailed="OnPlayerMediaFailed"
                              MediaOpened="OnPlayerMediaOpened" />

        <Grid Grid.RowSpan="5"
              BackgroundColor="#66000000"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   WidthRequest="44"
                                   HeightRequest="44" />
                <Label Text="{Binding BusyText}"
                       TextColor="White"
                       HorizontalTextAlignment="Center" />
            <HorizontalStackLayout Spacing="12"
                           IsVisible="{Binding ShowBusyActions}">
                <Button Text="中止"
                    Command="{Binding AbortBusyOperationCommand}"
                    IsVisible="{Binding CanAbortBusyOperation}"
                    BackgroundColor="#F59E0B"
                    TextColor="White" />
                <Button Text="取消"
                    Command="{Binding CancelBusyOperationCommand}"
                    IsVisible="{Binding CanCancelBusyOperation}"
                    BackgroundColor="#DC2626"
                    TextColor="White" />
            </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
