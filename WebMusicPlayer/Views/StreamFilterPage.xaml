<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:WebMusicPlayer.Models"
             x:Class="WebMusicPlayer.Views.StreamFilterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#73000000">

    <Grid Padding="20">
        <Border MaximumWidthRequest="560"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1B22}"
                Padding="20,18">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#66000000"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.24" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  RowSpacing="14">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10">
                    <Label Text="{x:Static models:AppIcons.Filter}"
                           FontFamily="{x:Static models:AppIcons.FontFamily}"
                           FontSize="22"
                           VerticalTextAlignment="Center" />
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="3">
                        <Label Text="筛选媒体流"
                               FontFamily="OpenSansSemibold"
                               FontSize="22" />
                        <Label Text="可以同时按来源与关键字过滤。关键字会匹配标题或 URL。"
                               FontSize="12"
                               Opacity="0.72" />
                    </VerticalStackLayout>
                    <Button Grid.Column="2"
                            Text="×"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            CornerRadius="20"
                            BackgroundColor="{AppThemeBinding Light=#F3F2FA, Dark=#2A2A35}"
                            TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                            Clicked="OnCancelClicked" />
                </Grid>

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="6">
                    <Label Text="关键字"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}"
                            BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}"
                            Padding="12,4">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry x:Name="KeywordEntry"
                               Placeholder="输入关键字，匹配标题或 URL"
                               ClearButtonVisibility="WhileEditing"
                               ReturnType="Done"
                               Completed="OnApplyClicked" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="6">
                    <Label Text="媒体流来源"
                           FontFamily="OpenSansSemibold"
                           FontSize="13" />
                    <Label Text="选择“全部来源”时，只应用关键字过滤。"
                           FontSize="12"
                           Opacity="0.62" />
                </VerticalStackLayout>

                <ScrollView Grid.Row="3"
                            MaximumHeightRequest="280">
                    <VerticalStackLayout x:Name="SourcesContainer"
                                         Spacing="10" />
                </ScrollView>

                <Grid Grid.Row="4"
                      ColumnDefinitions="Auto,*,*"
                      ColumnSpacing="12">
                    <Button Text="重置"
                            BackgroundColor="{AppThemeBinding Light=#ECE8FB, Dark=#2D2741}"
                            TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                            Clicked="OnResetClicked" />
                    <Button Grid.Column="1"
                            Text="取消"
                            BackgroundColor="{AppThemeBinding Light=#ECE8FB, Dark=#2D2741}"
                            TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                            Clicked="OnCancelClicked" />
                    <Button Grid.Column="2"
                            Text="应用筛选"
                            Clicked="OnApplyClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
