<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:WebMusicPlayer.Models"
             x:Class="WebMusicPlayer.Views.SubscriptionEditorPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#73000000">

    <Grid Padding="20">
        <Border MaximumWidthRequest="560"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1B1B22}"
                Padding="20,18">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#66000000"
                        Offset="0,8"
                        Radius="18"
                        Opacity="0.24" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                  RowSpacing="12">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="10">
                    <Label Text="{x:Static models:AppIcons.Subscription}"
                           FontFamily="{x:Static models:AppIcons.FontFamily}"
                           FontSize="22"
                           VerticalTextAlignment="Center" />
                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="4">
                        <Label x:Name="TitleLabel"
                               FontFamily="OpenSansSemibold"
                               FontSize="22" />
                        <Label x:Name="SubtitleLabel"
                               FontSize="13"
                               Opacity="0.74" />
                    </VerticalStackLayout>
                    <Button Grid.Column="2"
                            Text="×"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"
                            CornerRadius="20"
                            BackgroundColor="{AppThemeBinding Light=#F3F2FA, Dark=#2A2A35}"
                            TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                            Clicked="OnCancelClicked" />
                </Grid>

                <VerticalStackLayout Grid.Row="1" Spacing="6">
                    <Label Text="订阅名称" FontFamily="OpenSansSemibold" FontSize="13" />
                    <Border StrokeThickness="1" Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}" BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}" Padding="12,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <Entry x:Name="NameEntry" Placeholder="例如：我的电台合集" ClearButtonVisibility="WhileEditing" ReturnType="Next" Completed="OnNameCompleted" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Row="2" Spacing="6">
                    <Label Text="订阅地址" FontFamily="OpenSansSemibold" FontSize="13" />
                    <Border StrokeThickness="1" Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}" BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}" Padding="12,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                        <Entry x:Name="UrlEntry" Placeholder="https://example.com/subscription" ClearButtonVisibility="WhileEditing" Keyboard="Url" ReturnType="Next" Completed="OnUrlCompleted" />
                    </Border>
                </VerticalStackLayout>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="最大递归层数" FontFamily="OpenSansSemibold" FontSize="13" />
                        <Border StrokeThickness="1" Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}" BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}" Padding="12,4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Entry x:Name="DepthEntry" Placeholder="例如：6" Keyboard="Numeric" ReturnType="Next" Completed="OnDepthCompleted" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="最大媒体流数量" FontFamily="OpenSansSemibold" FontSize="13" />
                        <Border StrokeThickness="1" Stroke="{AppThemeBinding Light=#DDD7FA, Dark=#3B3453}" BackgroundColor="{AppThemeBinding Light=#FCFBFF, Dark=#23232D}" Padding="12,4">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                            <Entry x:Name="CountEntry" Placeholder="例如：1000" Keyboard="Numeric" ReturnType="Done" Completed="OnSaveClicked" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <Label Grid.Row="4"
                       x:Name="ErrorLabel"
                       TextColor="#DC2626"
                       FontSize="12"
                       IsVisible="False" />

                <Border Grid.Row="5"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#F6F4FF, Dark=#242036}"
                        Padding="12,10">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                    <Label Text="系统会使用队列解析 m3u/m3u8，并按你设置的递归层数和最大媒体流数量提前停止，避免超大订阅拖垮更新。"
                           FontSize="12"
                           Opacity="0.72" />
                </Border>

                <Grid Grid.Row="6" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Text="取消"
                            BackgroundColor="{AppThemeBinding Light=#ECE8FB, Dark=#2D2741}"
                            TextColor="{AppThemeBinding Light=#242424, Dark=White}"
                            Clicked="OnCancelClicked" />
                    <Button Grid.Column="1"
                            x:Name="SaveButton"
                            Clicked="OnSaveClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
